# ─── Azure AD / Microsoft Graph Configuration ───
# See docs/AZURE_SETUP_GUIDE.md for step-by-step instructions

# Your Azure AD Application (client) ID
VITE_AZURE_CLIENT_ID=your-client-id-here

# Your Azure AD Tenant (directory) ID
VITE_AZURE_TENANT_ID=your-tenant-id-here

# Redirect URI (must match what's registered in Azure AD)
VITE_REDIRECT_URI=http://localhost:5173

# Path to the shared Excel workbook in OneDrive/SharePoint
# Option A: Personal OneDrive path
VITE_EXCEL_WORKBOOK_PATH=/me/drive/root:/NetworkTracker.xlsx:
# Option B: SharePoint shared drive (recommended for teams)
# VITE_EXCEL_WORKBOOK_PATH=/drives/{driveId}/items/{itemId}
